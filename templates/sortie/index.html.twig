{% extends 'base.html.twig' %}

{% block title %}
    Liste des sorties
{% endblock %}

{% block body %}

    <section class="activities-section">

        <div class="section-header">
            <h1>Toutes les sorties</h1>

            <a href="{{ path('sortie_create') }}"
               class="btn-create">
                + Créer une sortie
            </a>
        </div>

        <form method="get" class="filters-card">

            <div class="filter-field filter-search">
                <label for="q">Recherche</label>
                <input
                    type="text"
                    id="q"
                    name="q"
                    placeholder="Nom, ville, lieu..."
                    value="{{ q|default('') }}"
                >
            </div>

            <div class="filter-field">
                <label for="dateMin">Début</label>
                <input type="date" name="dateMin" id="dateMin" value="{{ dateMin|default('') }}">
            </div>

            <div class="filter-field">
                <label for="dateMax">Fin</label>
                <input type="date" name="dateMax" id="dateMax" value="{{ dateMax|default('') }}">
            </div>

            <div class="filter-field">
                <label for="categorie">Catégorie</label>
                <select name="categorie" id="categorie">
                    <option value="">Toutes les catégories</option>
                    {% for categorie in categories %}
                        <option value="{{ categorie.id }}" {{ categorieId == categorie.id ? 'selected' : '' }}>
                            {{ categorie.nom }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="filter-field">
                <label for="departement">Campus</label>
                <select name="departement" id="departement">
                    <option value="">Tous les campus</option>
                    <option value="29" {{ departement == '29' ? 'selected' : '' }}>Quimper / Finistère</option>
                    <option value="44" {{ departement == '44' ? 'selected' : '' }}>Nantes / Loire-Atlantique</option>
                    <option value="35" {{ departement == '35' ? 'selected' : '' }}>Rennes / Ille-et-Vilaine</option>
                    <option value="79" {{ departement == '79' ? 'selected' : '' }}>Niort / Deux-Sèvres</option>
                </select>
            </div>

            <div class="filters-checks">
                <label class="filter-check"><input type="checkbox" name="organisateur" value="1" {{ organisateur ? 'checked' : '' }}> Sorties créées</label>
                <label class="filter-check"><input type="checkbox" name="inscrit" value="1" {{ inscrit ? 'checked' : '' }}> Mes inscriptions</label>
                <label class="filter-check"><input type="checkbox" name="disponible" value="1" {{ disponible ? 'checked' : '' }}> Disponibles</label>
                <label class="filter-check"><input type="checkbox" name="passees" value="1" {{ passees ? 'checked' : '' }}> Passées</label>
            </div>

            <div class="filter-actions">
                <button class="btn-primary" type="submit">Filtrer</button>
                <a href="{{ path('app_sortie') }}" class="btn-user">Réinitialiser</a>
            </div>

        </form>

        <br>

        <div class="activities-grid">

            {% for sortie in sorties %}

                <article class="activity-card">

                    <div class="card-image">
                        <img
                            src="{{ asset('images/' ~ (sortie.urlPhoto ?: 'default.png')) }}"
                            alt="{{ sortie.nom }}"
                        >
                    </div>

                    <div class="card-content">

                        <div class="card-tags">
                    <span class="location-badge">
                        {{ sortie.lieu.nomLieu }}
                    </span>

                            {% if sortie.categorie %}
                                <span
                                    class="category-badge"
                                    style="--category-color: {{ sortie.categorie.couleur }}"
                                >
                            {{ sortie.categorie.nom }}
                        </span>
                            {% endif %}
                        </div>

                        <h2>{{ sortie.nom }} à {{ sortie.lieu.ville.nomVille }}</h2>

                        <p class="description">
                            {{ sortie.description|length > 90
                            ? sortie.description|slice(0, 90) ~ '...'
                            : sortie.description
                            }}
                        </p>

                        <div class="card-meta">
                            📅 {{ sortie.dateDebut|date('d/m/Y H:i') }}
                        </div>
                        <div class="sortie-actions">

                            {% if sortie.etat == 0 %}

                                <a href="{{ path('sortie_detail', {'id': sortie.id}) }}" class="btn-detail">
                                    Voir détail
                                </a>

                                <div class="sortie-annulee-box">
                                    <p>Cette sortie est annulée.</p>

                                    {% if sortie.motifAnnulation %}
                                        <p><strong>Motif :</strong> {{ sortie.motifAnnulation }}</p>
                                    {% endif %}
                                </div>

                            {% else %}

                                <div class="actions-buttons">
                                    <a href="{{ path('sortie_detail', {'id': sortie.id}) }}" class="btn-detail">
                                        Voir détail
                                    </a>

                                    {% if app.user and sortie.organisateur and app.user.id == sortie.organisateur.id %}
                                        <button type="submit" form="annuler-{{ sortie.id }}" class="btn-danger">
                                            Annuler
                                        </button>
                                    {% endif %}
                                </div>

                                {% if app.user and sortie.organisateur and app.user.id == sortie.organisateur.id %}
                                    <form method="post"
                                          action="{{ path('sortie_annuler', {'id': sortie.id}) }}"
                                          id="annuler-{{ sortie.id }}"
                                          class="annulation-form">

                                        <input
                                            type="text"
                                            name="motif"
                                            placeholder="Motif d’annulation"
                                            required
                                            class="motif-input"
                                        >
                                    </form>
                                {% endif %}

                            {% endif %}

                        </div>

                    </div>

                </article>

            {% else %}
                <p>Aucune sortie disponible.</p>
            {% endfor %}

        </div>
    </section>

{% endblock %}
