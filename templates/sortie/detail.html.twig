{% extends 'base.html.twig' %}

{% block title %}Détail sortie{% endblock %}

{% block body %}

    <div class="detail-sortie-page">
        <div class="detail-card">

            <div class="detail-image">
                {% if sortie.urlPhoto %}
                    <img src="{{ asset('images/' ~ sortie.urlPhoto) }}" alt="{{ sortie.nom }}">
                {% else %}
                    <img src="{{ asset('images/default.jpg') }}" alt="image par défaut">
                {% endif %}

                <span class="badge">{{ sortie.lieu.nomLieu }}</span>
            </div>

            <div class="detail-content sortie-content">

                <h1>{{ sortie.nom }}</h1>

                <p>
                    <strong>Organisateur :</strong>
                    {% if organisateur %}
                        <a href="{{ path('profil_voir', {'id': organisateur.id}) }}">
                            {{ organisateur.prenom }} {{ organisateur.nom }}
                        </a>
                    {% else %}
                        <span>Organisateur inconnu</span>
                    {% endif %}
                </p>

                <h2>Détail de la sortie :</h2>
                <h3>On vous attend le :</h3>

                <div class="detail-infos infos-sortie">
                    <p><strong>Date :</strong> {{ sortie.dateDebut|date('d/m/Y') }}</p>
                    <p><strong>Heure :</strong> {{ sortie.dateDebut|date('H:i') }}</p>
                </div>

                <h3>Pensez à réserver :</h3>

                <div class="detail-infos infos-sortie">
                    <p><strong>Places disponibles :</strong> {{ sortie.nbInscriptionsMax - sortie.inscriptions|length }}</p>
                    <p><strong>Clôture des inscriptions :</strong> {{ sortie.dateCloture|date('d/m/Y') }}</p>
                </div>

                <div class="participants-section">
                    <h2>Participants inscrits ({{ sortie.inscriptions|length }})</h2>

                    {% if sortie.inscriptions|length > 0 %}
                        <ul class="participants-list">
                            {% for inscription in sortie.inscriptions %}
                                {% set participant = inscription.participant %}

                                {% if participant is not null %}
                                    <li class="participant-item">
                                        <a href="{{ path('profil_voir', {'id': participant.id}) }}">
                                            {{ participant.prenom }} {{ participant.nom }}
                                        </a>
                                    </li>
                                {% endif %}
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p>Aucun participant inscrit pour le moment.</p>
                    {% endif %}

                    {% if sortie.etat != 0 %}
                        {% if sortie.dateCloture > date() %}
                            <div class="participation-actions">
                                {% if dejaInscrit %}
                                    <form method="post" action="{{ path('sortie_desistement', {'id': sortie.id}) }}">
                                        <button type="submit" class="btn-primary">
                                            Se désister
                                        </button>
                                    </form>
                                {% else %}
                                    <form method="post" action="{{ path('sortie_inscription', {'id': sortie.id}) }}">
                                        <button type="submit" class="btn-primary">
                                            S'inscrire
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        {% else %}
                            <p>Clôture des inscriptions.</p>
                        {% endif %}
                    {% endif %}
                </div>

                <div class="actions-sortie">
                    {% if sortie.etat == 0 %}
                        <div class="annule-box">
                            <p><strong>Cette sortie est annulée.</strong></p>

                            {% if sortie.motifAnnulation %}
                                <p><strong>Motif :</strong> {{ sortie.motifAnnulation }}</p>
                            {% endif %}
                        </div>
                    {% else %}

                        {% if app.user and organisateur and app.user.id == organisateur.id %}
                            <form method="post" action="{{ path('sortie_annuler', {'id': sortie.id}) }}" class="annulation-form">
                                <input
                                    type="text"
                                    name="motif"
                                    placeholder="Motif d’annulation"
                                    required
                                >

                                <button type="submit" class="btn-danger">
                                    Annuler la sortie
                                </button>
                            </form>
                        {% endif %}
                    {% endif %}
                </div>

                <h2>À propos</h2>
                <div class="description">
                    <p>{{ sortie.description }}</p>
                </div>

            </div>
        </div>
    </div>

{% endblock %}
