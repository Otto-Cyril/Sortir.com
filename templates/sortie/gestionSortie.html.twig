{% extends 'base.html.twig' %}

{% block title %}
    Gérer les utilisateurs
{% endblock %}

{% block body %}
    <h1>Gestion des sorties</h1>

    <h3> Liste des Sorties </h3>

    <table>
        <thead>
        <tr>
            <th>Nom</th>
            <th>Date de début</th>
            <th>Date de fin</th>
            <th>nombre d'inscription max</th>
            <th>URL photo</th>
            <th>organisateur</th>
            <th>lieu</th>
            <th>Catégorie</th>
            <th>état</th>
            <th>motif d'annulation</th>
            <th>action</th>
        </tr>
        </thead>
        <tbody>
        {% for sortie in sorties %}

            <tr>

                <td>{{ sortie.nom }}</td>
                <td>{{ sortie.dateDebut |date("d/m/Y")  }}</td>
                <td>{{ sortie.dateCloture |date("d/m/Y") }}</td>
                <td>{{ sortie.nbInscriptionsMax}}</td>
                <td>{{ sortie.urlPhoto }}</td>
                <td>{{ sortie.organisateur.getPseudo() }}</td>
                <td>{{ sortie.lieu.getNomLieu() }}</td>
                <td>{{ sortie.categorie.nom }}</td>
                <td>
                    {% if sortie.etat  == 0    %}
                        archivé
                    {% elseif sortie.motifAnnulation != null  %}
                        annulé
                    {% elseif sortie.etat  == 1 %}
                        en ligne
                    {% endif %}

                </td>
                {% if sortie.motifAnnulation != null %}
                <th>{{ sortie.motifAnnulation }}</th>
                {% else %}
                    <th>-</th>
                {% endif %}
                <td>
                    {% if sortie.motifAnnulation == null %}
                    <a href="{{ path('sortie_detail', {'id': sortie.id}) }}" class="btn-create tableaubtn">annuler</a>
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

{% endblock %}
